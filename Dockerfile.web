FROM node:22-slim AS builder

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# Workspace config files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY tsconfig.base.json tsconfig.json ./

# package.json files for all packages (layer cache)
COPY lib/db/package.json ./lib/db/
COPY lib/api-spec/package.json ./lib/api-spec/
COPY lib/api-zod/package.json ./lib/api-zod/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY artifacts/vvsu-tourism/package.json ./artifacts/vvsu-tourism/
COPY scripts/package.json ./scripts/

# Install ALL dependencies
RUN pnpm install --frozen-lockfile

# Copy source
COPY lib/ ./lib/
COPY artifacts/vvsu-tourism/ ./artifacts/vvsu-tourism/
COPY scripts/ ./scripts/

# Build shared libs (generates type declarations needed by Vite)
RUN pnpm run typecheck:libs

# Build the frontend
# PORT and BASE_PATH are required by vite.config.ts (it throws if they are missing).
# PORT is only used for the dev server — any valid port works for a production build.
# BASE_PATH=/ means the app is served from the root of the domain.
RUN PORT=3000 BASE_PATH=/ NODE_ENV=production \
    pnpm --filter @workspace/vvsu-tourism run build

# Verify the build output exists
RUN ls -la /app/artifacts/vvsu-tourism/dist/public/index.html

# --- Nginx image ---
FROM nginx:alpine AS runtime

# vite.config.ts outputs to dist/public (not dist/)
COPY --from=builder /app/artifacts/vvsu-tourism/dist/public /usr/share/nginx/html

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
