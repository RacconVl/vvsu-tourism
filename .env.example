# ============================================================
# Обязательные переменные окружения
# ============================================================

# Строка подключения к PostgreSQL
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vvsu_tourism

# Секрет для подписи JWT-токенов и сессий (минимум 32 символа)
# Сгенерируйте: openssl rand -base64 32
SESSION_SECRET=replace-this-with-a-long-random-secret-string
